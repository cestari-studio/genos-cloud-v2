{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": [
      "ES2022"
    ],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "shared/**/*.ts",
    "scripts/**/*.ts",
    "infra/supabase/functions/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "infra/supabase/functions",
    "legacy"
  ]
}