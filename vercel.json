{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd apps/ui-react && npm install && npm run build",
  "outputDirectory": "apps/ui-react/dist",
  "framework": "vite",
  "installCommand": "echo 'install handled in buildCommand'",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}