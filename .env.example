# ==========================================================
# genOS Cloud v2 - Environment Variables
# ==========================================================

# Node.js Server
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://genos.cestari.studio

# Supabase (Database + Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key

# Wix Integration
WIX_API_KEY=your_wix_api_key
WIX_SITE_ID=your_wix_site_id
WIX_CLIENT_ID=your_wix_client_id
WIX_OAUTH_REDIRECT_URI=https://genos.cestari.studio/auth/callback

# AI (Gemini)
GEMINI_API_KEY=your_gemini_api_key

# Vite Frontend (prefix with VITE_)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
