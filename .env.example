# ==========================================================
# genOS™ Lumina Enterprise - Production Environment Variables
# ==========================================================

# 1. 🌐 Node.js Proxy Core (Express)
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://genos.cestari.studio

# 2. 🔐 Wix Headless Identity Broker (OAuth2)
WIX_CLIENT_ID=your_enterprise_wix_client_id
WIX_OAUTH_REDIRECT_URI=https://genos.cestari.studio/auth/callback

# 3. 🧠 Agentic Workflows (IBM Watsonx)
IBM_CLOUD_API_KEY=your_ibm_cloud_key
WATSONX_PROJECT_ID=your_project_id
WATSONX_REGION=us-south

# 4. 🗄️ Master Database (Supabase / Row Level Security Guard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_secret_role_key

# 5. 🔭 Quantum Observability (Qiskit Drift Monitoring)
QISKIT_API_TOKEN=your_ibm_quantum_token
CRX_OBSERVATORY_LEVEL=HIGH

# 6. 💳 Billing / Stripe Rate Limiter
STRIPE_SECRET_KEY=sk_live_12345
TOKEN_QUOTA_ENTERPRISE=50000000
